# Konfiguracja bazy danych:

# Użyj host.docker.internal jeśli uruchamiasz program na Windows lub MacOS a twoja baza danych jest uruchomiona lokalnie
# W przypadku systemu opartego na Linuxie, użyj adresu 172.17.0.1
# Jeśli twoja baza danych jest gdzieś zewnętrznie podaj po prostu jej adres IP naprzykład: 192.168.1.100
DB_HOST=172.17.0.1
# Port bazy danych:
DB_PORT=3306
# Dane logowania do bazy danych:
DB_USER=root
DB_PASSWORD=zaq1@WSX
# Nazwa bazy danych:
DB_NAME=bazaDanych
# Nazwa tabeli:
DB_TABLE=bookings
# Nazwa kolumny z datą:
DB_DATE_COLUMN=date
# Czas po którym rekordy mają być usuwane (1 DAY, 2 MONTH, 3 YEAR):
# Podane bez znaków '' lub ""
DB_INTERVAL=1 MONTH