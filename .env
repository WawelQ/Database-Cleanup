# Configuring the database connection

# Use host.docker.internal if you are running the program on Windows or MacOS and your database is running locally
# For Linux-based systems, use the address 172.17.0.1
# If your database is somewhere else, simply provide its IP address for example: 192.168.1.100
DB_HOST=172.17.0.1
# Port of the database:
DB_PORT=3306
# Database login credentials:
DB_USER=root
DB_PASSWORD=zaq1@WSX
# Database name:
DB_NAME=bazaDanych
# Table name from which the data will be deleted:
DB_TABLE=bookings
# Name of the column containing the date:
DB_DATE_COLUMN=date
# Time after which records will be deleted (1 DAY, 2 MONTH, 3 YEAR):
# Remember to provide them without quotes!
DB_INTERVAL=1 MONTH